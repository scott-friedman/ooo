{
  "rules": {
    // ========================================
    // CONTENT - Public read, admin write only
    // ========================================
    "content": {
      ".read": true,
      ".write": "auth != null && root.child('admins').child(auth.uid).exists()"
    },

    // ========================================
    // PAGES - Public read, admin write only
    // ========================================
    "pages": {
      ".read": true,
      ".write": "auth != null && root.child('admins').child(auth.uid).exists()"
    },

    // ========================================
    // BENEFITS - Controlled access
    // ========================================
    "benefits": {
      // Cache: Public read, only authenticated workers can write
      "cache": {
        ".read": true,
        ".write": "auth != null",
        "$cacheKey": {
          ".validate": "newData.hasChildren(['benefits', 'usageTips', 'cachedAt']) &&
                        newData.child('benefits').isString() == false &&
                        newData.child('cachedAt').isNumber()"
        }
      },
      // History: Public read/write with validation
      "history": {
        ".read": true,
        ".write": true,
        "$historyId": {
          ".validate": "newData.hasChildren(['query', 'timestamp'])",
          "query": { ".validate": "newData.isString() && newData.val().length <= 200" },
          "timestamp": { ".validate": "newData.isNumber() && newData.val() <= now + 300000" },
          "$other": { ".validate": false }
        }
      },
      // Expansions: Public read, only authenticated can write
      "expansions": {
        ".read": true,
        ".write": "auth != null",
        "$expansionKey": {
          ".validate": "newData.hasChildren(['expansion', 'cachedAt'])"
        }
      }
    },

    // ========================================
    // STICKY NOTES - Validated (enable App Check for abuse protection)
    // ========================================
    "stickynotes": {
      ".read": true,
      // Admin can clear the entire board in one shot (delete all notes).
      // Mirrors the strokes clear pattern: admin + deletion only. (P3-3)
      ".write": "auth != null && root.child('admins').child(auth.uid).exists() && !newData.exists()",
      "$noteId": {
        // Create a new note: anyone (this page has no auth).
        // Move/restyle an existing note: anyone, BUT text & createdAt must be
        //   unchanged, so movers can reposition/recolor but not rewrite words.
        // Delete a single note: admin only (newData absent -> falls to admin clause).
        ".write": "!data.exists() || (newData.exists() && newData.child('text').val() == data.child('text').val() && newData.child('createdAt').val() == data.child('createdAt').val()) || (auth != null && root.child('admins').child(auth.uid).exists())",
        ".validate": "newData.hasChildren(['text', 'x', 'y', 'color', 'createdAt']) &&
                      newData.child('text').isString() &&
                      newData.child('text').val().length >= 1 &&
                      newData.child('text').val().length <= 200 &&
                      newData.child('x').isNumber() &&
                      newData.child('x').val() >= -10 &&
                      newData.child('x').val() <= 110 &&
                      newData.child('y').isNumber() &&
                      newData.child('y').val() >= 0 &&
                      newData.child('y').val() <= 20000 &&
                      newData.child('color').isString() &&
                      newData.child('color').val().matches(/^(yellow|pink|blue|green|orange|purple)$/) &&
                      (!newData.hasChild('font') || newData.child('font').val().matches(/^(caveat|patrick|marker)$/)) &&
                      (!newData.hasChild('rotation') || newData.child('rotation').isNumber()) &&
                      newData.child('createdAt').isNumber() &&
                      newData.child('createdAt').val() <= now + 300000"
      }
    },

    // ========================================
    // DRAWING STROKES - Public with validation
    // ========================================
    "strokes": {
      ".read": true,
      "$pageId": {
        // Validate page ID is a known page
        ".validate": "$pageId.matches(/^[a-zA-Z0-9_-]+$/)",
        // Admin can remove all strokes for a page (clear canvas)
        ".write": "auth != null && root.child('admins').child(auth.uid).exists() && !newData.exists()",
        "$strokeId": {
          ".write": true,
          // Point cap: a real stroke is a few hundred points; index 2000
          // absent bounds the payload without counting children (which
          // rules can't do). (SEC-3)
          ".validate": "newData.hasChildren(['points', 'width', 'timestamp']) &&
                        newData.child('width').isNumber() &&
                        newData.child('width').val() >= 1 &&
                        newData.child('width').val() <= 50 &&
                        newData.child('timestamp').isNumber() &&
                        newData.child('timestamp').val() <= now + 300000 &&
                        newData.child('points').hasChildren() &&
                        !newData.child('points').child('2000').exists()"
        }
      }
    },

    // ========================================
    // CANVAS CLEARED - Admin only
    // ========================================
    "canvas_cleared": {
      ".read": true,
      "$pageId": {
        ".write": "auth != null && root.child('admins').child(auth.uid).exists()",
        ".validate": "newData.isNumber()"
      }
    },

    // ========================================
    // COMMAND CENTER - Strict admin control
    // ========================================
    "commandcenter": {
      "enabled": {
        ".read": true,
        ".write": "auth != null && root.child('admins').child(auth.uid).exists()",
        ".validate": "newData.isBoolean()"
      },
      "devices": {
        ".read": true,
        ".write": "auth != null && root.child('admins').child(auth.uid).exists()"
      },
      // Log entries are written by the HA proxy worker using the database
      // secret (which bypasses rules); public writes are denied. Admin can
      // clear the log. Publicly readable — the command center page shows it.
      "log": {
        ".read": true,
        ".write": "auth != null && root.child('admins').child(auth.uid).exists()",
        ".indexOn": ["timestamp"],
        "$logId": {
          ".validate": "newData.hasChildren(['entity_id', 'action', 'timestamp']) &&
                        newData.child('entity_id').isString() &&
                        newData.child('entity_id').val().length <= 100 &&
                        newData.child('action').isString() &&
                        newData.child('action').val().length <= 50 &&
                        (!newData.hasChild('deviceName') || (newData.child('deviceName').isString() && newData.child('deviceName').val().length <= 60)) &&
                        newData.child('timestamp').isNumber()"
        }
      }
    },

    // ========================================
    // MUSIC - Public collaborative feature
    // ========================================
    "music": {
      ".read": true,
      // Bars/songs are create-only for the public (the page never edits
      // them after save); admin can delete spam. String/number bounds keep
      // this from being a free arbitrary-JSON store. (SEC-3)
      "bars": {
        "$barId": {
          ".write": "!data.exists() || (auth != null && root.child('admins').child(auth.uid).exists() && !newData.exists())",
          ".validate": "newData.hasChildren(['drums', 'melody', 'name', 'creator', 'createdAt']) &&
                        newData.child('name').isString() &&
                        newData.child('name').val().length <= 60 &&
                        newData.child('creator').isString() &&
                        newData.child('creator').val().length <= 60 &&
                        (!newData.hasChild('bpm') || (newData.child('bpm').isNumber() && newData.child('bpm').val() >= 20 && newData.child('bpm').val() <= 400)) &&
                        newData.child('createdAt').isNumber() &&
                        newData.child('createdAt').val() <= now + 300000"
        }
      },
      "songs": {
        "$songId": {
          ".write": "!data.exists() || (auth != null && root.child('admins').child(auth.uid).exists() && !newData.exists())",
          ".validate": "newData.hasChildren(['name', 'creator', 'barIds', 'createdAt'])",
          "name": { ".validate": "newData.isString() && newData.val().length <= 60" },
          "creator": { ".validate": "newData.isString() && newData.val().length <= 60" },
          "barIds": {
            ".validate": "newData.hasChildren() && !newData.child('100').exists()",
            "$idx": { ".validate": "newData.isString() && newData.val().length <= 64" }
          },
          "createdAt": { ".validate": "newData.isNumber() && newData.val() <= now + 300000" },
          "$other": { ".validate": false }
        }
      }
    },

    // ========================================
    // LITTER ROBOT - Read only (external update)
    // Home Assistant writes via the database secret (?auth=), which
    // bypasses rules — public writes stay denied.
    // ========================================
    "litterrobot": {
      ".read": true,
      ".write": false
    },

    // ========================================
    // FIGURINES - Public read/create/interact, admin delete
    // Mirrors the stickynotes pattern: anyone can add a figurine or
    // interact (move/pet/feed change stats), but name and model are
    // immutable after creation and only admin can delete.
    // ========================================
    "figurines": {
      ".read": true,
      ".write": "auth != null && root.child('admins').child(auth.uid).exists() && !newData.exists()",
      "$figurineId": {
        ".write": "!data.exists() || (newData.exists() && newData.child('modelUrl').val() == data.child('modelUrl').val() && newData.child('name').val() == data.child('name').val()) || (auth != null && root.child('admins').child(auth.uid).exists())",
        ".validate": "newData.hasChildren(['modelUrl', 'name', 'x', 'z'])",
        "modelUrl": { ".validate": "newData.isString() && newData.val().beginsWith('https://firebasestorage.googleapis.com/') && newData.val().length <= 2048" },
        "name": { ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 60" },
        "x": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100" },
        "z": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100" },
        "rotationY": { ".validate": "newData.isNumber()" },
        "state": { ".validate": "newData.isString() && newData.val().length <= 60" },
        "hunger": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100" },
        "happiness": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100" },
        "energy": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100" },
        "lastInteraction": { ".validate": "newData.isNumber()" },
        // Timestamp of the last authoritative stat write (client materializes
        // effective stats on interaction; the keeper worker on its cron)
        "statsUpdatedAt": { ".validate": "newData.isNumber() && newData.val() <= now + 300000" },
        // Shared stroll path: every client animates position from this via
        // timestamp math; removed (null) when the stroll ends
        "walk": {
          ".validate": "newData.hasChildren(['fromX', 'fromZ', 'toX', 'toZ', 'startedAt', 'duration'])",
          "fromX": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100" },
          "fromZ": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100" },
          "toX": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100" },
          "toZ": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100" },
          "startedAt": { ".validate": "newData.isNumber() && newData.val() <= now + 300000" },
          "duration": { ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 60000" },
          "$other": { ".validate": false }
        },
        "$other": { ".validate": false }
      }
    },

    // ========================================
    // CARETAKERS - Worker-only (database secret bypasses rules)
    // Holds email addresses; must NEVER be publicly readable.
    // ========================================
    "caretakers": {
      ".read": false,
      ".write": false
    },
    // Public caretaker counts per figurine, maintained by the keeper worker
    "caretakerCounts": {
      ".read": true,
      ".write": false
    },
    // Notification cooldown state, worker-only
    "notifyState": {
      ".read": false,
      ".write": false
    },

    // ========================================
    // ADMIN CONFIG - Never publicly accessible
    // ========================================
    "admins": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": false
      }
    },
    "admin_config": {
      ".read": "auth != null && root.child('admins').child(auth.uid).exists()",
      ".write": "auth != null && root.child('admins').child(auth.uid).exists()"
    },

    // ========================================
    // DEFAULT - Deny all other paths
    // ========================================
    "$other": {
      ".read": false,
      ".write": false
    }
  }
}
